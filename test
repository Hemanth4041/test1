def export_values_to_gcs_logic(file_name: str, sql_query: str) -> str:
    """
    Executes a SQL query against BigQuery and uploads the results as a CSV directly to a GCS bucket.

    Args:
        file_name (str): The desired base name of the file (e.g., 'finance_audience.csv').
        sql_query (str): The SQL query string drafted by the agent.

    Returns:
        str: A success or error message for the ADK orchestrator to read.
    """
    bucket_name = os.getenv("AUDIENCE_SEGMENTATION_EXPORTS_BUCKET")
    try:
        # 1. Append a timestamp to the filename to prevent overwriting
        if file_name.endswith(".csv"):
            base_name = file_name[:-4]
        else:
            base_name = file_name

        timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        final_file_name = f"{base_name}_{timestamp}.csv"

        # 2. Execute the BigQuery Query
        # In the ADK environment, this automatically uses Application Default Credentials (ADC).
        bq_client = bigquery.Client()
        query_job = bq_client.query(sql_query)

        # Convert the results to a Pandas DataFrame, then to a CSV string
        df = query_job.to_dataframe()
        csv_content = df.to_csv(index=False)

        # 3. Upload the CSV content directly to GCS
        storage_client = storage.Client()
        bucket = storage_client.bucket(bucket_name)
        blob = bucket.blob(final_file_name)

        blob.upload_from_string(csv_content, content_type="text/csv")

        success_msg = f"Success: File '{final_file_name}' containing {len(df)} records was uploaded to bucket '{bucket_name}'."

        # Log the success so you can see it in GCP!
        logger.info(success_msg)

        return success_msg

    except Exception as e:
        logger.error(f"Failed to export audience to GCS: {str(e)}", exc_info=True)
        return f"Error executing query or uploading to GCS: {str(e)}"


